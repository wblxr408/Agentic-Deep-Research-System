# LLM API Keys
LLM_PROVIDER=qwen
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_MODEL=qwen-plus

# Fallback LLM
FALLBACK_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat-v3

# Database
DATABASE_URL=postgresql://deepintel:deepintel_secret@localhost:5432/deepintel

# Redis
REDIS_URL=redis://localhost:6379/0

# RAG
RAG_EMBED_MODEL=BAAI/bge-zh-qwen2-int8
RAG_EMBED_DIMENSION=1024
RAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANK_DEVICE=cpu
RAG_RETRIEVAL_TOP_K=20
RAG_RERANK_TOP_N=10
RAG_RRF_K=60

# Browser
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_POOL_SIZE=2
PLAYWRIGHT_NAVIGATION_TIMEOUT=30000

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
API_LOG_LEVEL=INFO
